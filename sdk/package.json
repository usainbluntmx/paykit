{
  "name": "@paykit-labs/sdk",
  "version": "0.1.0",
  "description": "PayKit SDK - Autonomous AI Agent Payments on Solana",
  "main": "src/index.js",
  "types": "src/types.ts",
  "files": [
    "src/",
    "idl/",
    "examples/"
  ],
  "exports": {
    ".": {
      "require": "./src/index.js",
      "types": "./src/types.ts"
    },
    "./errors": {
      "require": "./src/errors.js",
      "types": "./src/types.ts"
    }
  },
  "scripts": {
    "test": "jest --testTimeout=30000 --forceExit",
    "test:integration": "node src/test.js",
    "patch-idl": "node src/patch-idl.js",
    "build": "cd .. && anchor build && cd sdk && node src/patch-idl.js",
    "server": "node src/server.js",
    "server:mainnet": "node src/server.js 3333 ~/.config/solana/id.json mainnet-beta",
    "server:pm2": "pm2 start src/server.js --name paykit-sidecar",
    "example": "node examples/basic-usage.js"
  },
  "jest": {
    "testMatch": [
      "**/__tests__/**/*.test.js"
    ]
  },
  "bin": {
    "paykit": "src/cli.js"
  },
  "keywords": [
    "solana",
    "payments",
    "ai-agents",
    "web3",
    "autonomous-agents",
    "anchor"
  ],
  "author": "Zero Two Labs",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@coral-xyz/anchor": "0.31.1",
    "@solana/spl-token": "^0.4.14",
    "@solana/web3.js": "^1.98.0",
    "bs58": "^6.0.0",
    "dotenv": "^16.0.0"
  },
  "devDependencies": {
    "jest": "^30.3.0",
    "@anthropic-ai/sdk": "^0.87.0"
  }
}